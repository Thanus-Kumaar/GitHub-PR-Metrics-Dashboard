	column 'PR Size Bucket Expanded' =
			
			SWITCH(
			    TRUE(),
			    prs[pr_size] = 0, "0",
			    prs[pr_size] <= 50, "1–50",
			    prs[pr_size] <= 200, "51–200",
			    prs[pr_size] <= 500, "201–500",
			    prs[pr_size] <= 1000, "501–1k",
			    prs[pr_size] <= 5000, "1k–5k",
			    prs[pr_size] <= 10000, "5k–10k",
			    prs[pr_size] <= 50000, "10k–50k",
			    "50k+"
			)
		lineageTag: 07428a7f-a197-400d-aeb3-959a9145af4c
		summarizeBy: none
		sortByColumn: 'PR Size Bucket Sort'

		changedProperty = SortByColumn

		annotation SummarizationSetBy = Automatic

	column 'PR Size Bucket Sort' =
			
			SWITCH(
			    TRUE(),
			    prs[pr_size] = 0, 1,
			    prs[pr_size] <= 50, 2,
			    prs[pr_size] <= 200, 3,
			    prs[pr_size] <= 500, 4,
			    prs[pr_size] <= 1000, 5,
			    prs[pr_size] <= 5000, 6,
			    prs[pr_size] <= 10000, 7,
			    prs[pr_size] <= 50000, 8,
			    9
			)
		formatString: 0
		lineageTag: 1ce6d014-975f-47b5-b473-302b162fbb42
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

