		annotation SummarizationSetBy = Automatic

	column 'review_comments_count (bins)' =
			IF(
				ISBLANK('prs'[review_comments_count]),
				BLANK(),
				INT('prs'[review_comments_count] / 2) * 2
			)
		formatString: 0
