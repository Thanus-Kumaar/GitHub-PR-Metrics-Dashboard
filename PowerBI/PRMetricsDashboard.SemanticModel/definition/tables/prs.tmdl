	column 'pr_size (bins)' =
			IF(
				ISBLANK('prs'[pr_size]),
				BLANK(),
				INT('prs'[pr_size] / 17839) * 17839
			)
		formatString: 0
		lineageTag: f75bc9e1-bcf5-4875-905d-c03663fae458
		summarizeBy: none

